&lt;html lang="en"&gt;
&lt;head&gt;
    &lt;meta charset="UTF-8"&gt;
    &lt;title&gt;Invalid Quantity&lt;/title&gt;
    &lt;script src="https://cdn.tailwindcss.com"&gt;&lt;/script&gt;
&lt;/head&gt;

&lt;body class="bg-gray-100 flex items-center justify-center h-screen"&gt;

    &lt;div class="bg-white p-6 rounded-2xl shadow-lg max-w-md text-center"&gt;

        &lt;!-- Warning Icon --&gt;
        &lt;div class="text-red-500 text-4xl mb-3"&gt;
            ⚠️
        &lt;/div&gt;

        &lt;!-- Title --&gt;
        &lt;h1 class="text-xl font-bold text-red-600 mb-2"&gt;
            Invalid Quantity
        &lt;/h1&gt;

        &lt;!-- Message --&gt;
        &lt;p class="text-gray-700"&gt;
            Product quantity should not be zero or negative.
        &lt;/p&gt;

        &lt;!-- Highlight --&gt;
        &lt;div class="mt-4 bg-red-100 text-red-700 p-2 rounded-lg text-sm"&gt;
            Please enter a value greater than 0.
        &lt;/div&gt;

    &lt;/div&gt;

&lt;/body&gt;
&lt;/html&gt;</value>
