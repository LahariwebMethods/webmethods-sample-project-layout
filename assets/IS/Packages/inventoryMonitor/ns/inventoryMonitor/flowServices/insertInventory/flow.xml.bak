<MAPSET NAME="Setter" OVERWRITE="true" VARIABLES="true" GLOBALVARIABLES="false" FIELD="/Message;1;0">
  <DATA ENCODING="XMLValues" I18N="true">

<Values version="2.0">
  <value name="xml">&lt;!DOCTYPE html&gt;
&lt;html lang="en"&gt;
&lt;head&gt;
    &lt;meta charset="UTF-8"&gt;
    &lt;title&gt;Product Inserted&lt;/title&gt;
    &lt;script src="https://cdn.tailwindcss.com"&gt;&lt;/script&gt;
&lt;/head&gt;

&lt;body class="bg-gray-100 p-6"&gt;

    &lt;div class="max-w-3xl mx-auto bg-white rounded-2xl shadow-lg p-6"&gt;

        &lt;!-- Title --&gt;
        &lt;h1 class="text-2xl font-bold text-center text-blue-600 mb-6"&gt;
            PRODUCT INSERTED
        &lt;/h1&gt;

        &lt;!-- Success Message --&gt;
        &lt;div class="bg-green-100 text-green-700 p-3 rounded-lg text-center font-medium mb-6"&gt;
            ✅ New product has been successfully added
        &lt;/div&gt;

        &lt;!-- Product Details Card --&gt;
        &lt;div class="border rounded-xl p-4 shadow-sm hover:shadow-md transition"&gt;

            &lt;div class="grid grid-cols-2 gap-4 text-gray-700"&gt;

                &lt;div&gt;
                    &lt;p class="text-sm text-gray-500"&gt;Product ID&lt;/p&gt;
                    &lt;p class="font-semibold"&gt;%inventoryMonitor.docs:inventoryDoc/P_ID%&lt;/p&gt;
                &lt;/div&gt;

                &lt;div&gt;
                    &lt;p class="text-sm text-gray-500"&gt;Product Name&lt;/p&gt;
                    &lt;p class="font-semibold"&gt;%inventoryMonitor.docs:inventoryDoc/P_Name%&lt;/p&gt;
                &lt;/div&gt;

                &lt;div&gt;
                    &lt;p class="text-sm text-gray-500"&gt;Quantity&lt;/p&gt;
                    &lt;p class="font-semibold text-green-600"&gt;
                        %inventoryMonitor.docs:inventoryDoc/Quantity%
                    &lt;/p&gt;
                &lt;/div&gt;

                &lt;div&gt;
                    &lt;p class="text-sm text-gray-500"&gt;Threshold&lt;/p&gt;
                    &lt;p class="font-semibold"&gt;%inventoryMonitor.docs:inventoryDoc/Threshold%&lt;/p&gt;
                &lt;/div&gt;

                &lt;div class="col-span-2"&gt;
                    &lt;p class="text-sm text-gray-500"&gt;Amount&lt;/p&gt;
                    &lt;p class="font-semibold text-blue-600"&gt;
                        ₹ %inventoryMonitor.docs:inventoryDoc/Amount%
                    &lt;/p&gt;
                &lt;/div&gt;

            &lt;/div&gt;

        &lt;/div&gt;

    &lt;/div&gt;

&lt;/body&gt;
&lt;/html&gt;</value>
  <record name="type" javaclass="com.wm.util.Values">
    <value name="node_type">unknown</value>
    <value name="node_subtype">unknown</value>
    <value name="is_public">false</value>
    <value name="field_name">Message</value>
    <value name="field_type">string</value>
    <value name="field_dim">0</value>
    <value name="nillable">true</value>
    <value name="form_qualified">false</value>
    <value name="is_global">false</value>
  </record>
</Values>
</DATA>
