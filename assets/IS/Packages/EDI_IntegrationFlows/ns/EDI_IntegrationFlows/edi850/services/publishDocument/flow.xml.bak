    <value name="nillable">true</value>
    <value name="form_qualified">false</value>
    <value name="is_global">false</value>
  </record>
</Values>
</DATA>
</MAPSET>

<MAPDELETE FIELD="/documentTypeName;1;0">
</MAPDELETE>

<MAPDELETE FIELD="/local;1;0">
</MAPDELETE>

<MAPDELETE FIELD="/serviceName;1;0">
</MAPDELETE>
</MAP>
</INVOKE>
</LOOP>
</SEQUENCE>

<SEQUENCE TIMEOUT="" EXIT-ON="FAILURE" FORM="CATCH">
  <COMMENT></COMMENT>

  <!-- nodes -->

<INVOKE TIMEOUT="" SERVICE="pub.flow:getLastError" VALIDATE-IN="$none" VALIDATE-OUT="$none">
  <COMMENT></COMMENT>

  <!-- nodes -->

<MAP MODE="OUTPUT">
</MAP>
</INVOKE>

<EXIT FROM="$flow" SIGNAL="FAILURE" FAILURE-MESSAGE="%lastError/error%">
  <COMMENT></COMMENT>
</EXIT>
</SEQUENCE>
</FLOW>
