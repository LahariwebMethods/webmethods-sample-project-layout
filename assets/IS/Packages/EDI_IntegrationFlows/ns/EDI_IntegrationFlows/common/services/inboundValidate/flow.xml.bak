<MAPCOPY FROM="/lastError;4;0;pub.event:exceptionInfo/error;1;0" TO="/fullMessage;1;0">
</MAPCOPY>

<MAPCOPY FROM="/lastError;4;0;pub.event:exceptionInfo/service;1;0" TO="/briefMessage;1;0">
</MAPCOPY>
</MAP>
</INVOKE>

<EXIT FROM="$flow" SIGNAL="SUCCESS" FAILURE-MESSAGE="EDI_IntegrationFlows.common.services:inboundValidate:- %lastError/error%">
  <COMMENT></COMMENT>
</EXIT>
</SEQUENCE>
</FLOW>
